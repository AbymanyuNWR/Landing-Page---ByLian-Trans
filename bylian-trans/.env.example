# ==========================================
# ENV TEMPLATE — PT BYLIAN TRANS Tegal
# ==========================================

# 1. APPLICATION
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 2. DATABASE (Supabase / Postgres)
DATABASE_URL="postgresql://postgres:password@localhost:5432/bylian"
DIRECT_URL="postgresql://postgres:password@localhost:5432/bylian"

# 3. REDIS (Upstash)
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxx"

# 4. AUTH & SECURITY
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-random-secret-here"
AUTH_GOOGLE_ID="google-client-id"
AUTH_GOOGLE_SECRET="google-client-secret"

# 5. PAYMENT (Midtrans)
MIDTRANS_SERVER_KEY="SB-Mid-server-xxx"
MIDTRANS_CLIENT_KEY="SB-Mid-client-xxx"
MIDTRANS_IS_PRODUCTION="false"

# 6. COMMUNICATION (Email & WA)
RESEND_API_KEY="re_123456789"
FONNTE_TOKEN="fonnte-api-token"
NEXT_PUBLIC_WHATSAPP_NUMBER="6281234567890"
NEXT_PUBLIC_WHATSAPP_CHARTER="6281234567891"

# 7. GPS TRACKING & MAPS
GPS_WEBHOOK_SECRET="super-secret-gps-webhook-key"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSy-xxx"

# 8. ANALYTICS
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# 9. STORAGE (Cloudinary)
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
